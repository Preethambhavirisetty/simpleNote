# Agent Workflow Service — standalone runtime on port 5453

AGENT_WORKFLOW_HOST=0.0.0.0
AGENT_WORKFLOW_PORT=5453
# Optional. When set, clients must send X-API-Key with this value.
AGENT_WORKFLOW_API_KEY=

# Debug-only per-turn trace. Shows one-line LLM/token events on final responses.
AGENT_WORKFLOW_DEBUG_TRACE=false

# LLM (OpenAI-compatible inference service)
LLM_API_BASE_GENERAL=http://127.0.0.1:8001/v1
LLM_API_KEY=
LLM_MODEL=reasoner
LLM_SEND_AUTH_HEADER=true
LLM_TEMPERATURE=0.2
LLM_TOP_P=0.9
LLM_TOP_K=40
LLM_SEED=42

# Default MCP (YAML agents can override via mcp.servers)
MCP_URL=http://127.0.0.1:8970/mcp
MCP_AUTH_TOKEN=

# Optional semantic tool index search (Agent Studio / mcp-service reference impl)
TOOL_INDEX_SEARCH_URL=http://127.0.0.1:8970/internal/connector-tools/search
TOOL_INDEX_API_KEY=

# Optional cross-turn artifact persistence (requires Redis URL + policy flag)
AGENT_WORKFLOW_REDIS_URL=
# AGENT_WORKFLOW_CROSS_TURN_ARTIFACTS=true

# Default exploration profile when a request does not set runtime_context.exploration_profile
# quick | heavy
DEFAULT_EXPLORATION_PROFILE=quick

# Async per-step logging to Splunk HTTP Event Collector (background thread, non-blocking).
# Disabled unless SPLUNK_HEC_ENABLED=true AND both URL and TOKEN are set.
SPLUNK_HEC_ENABLED=false
SPLUNK_HEC_URL=https://splunk:8088/services/collector/event
SPLUNK_HEC_TOKEN=
SPLUNK_HEC_INDEX=
SPLUNK_HEC_SOURCE=agent-workflow
SPLUNK_HEC_SOURCETYPE=agent_workflow:step
SPLUNK_HEC_VERIFY_SSL=true
SPLUNK_HEC_BATCH_SIZE=50
SPLUNK_HEC_FLUSH_INTERVAL_SECONDS=2
SPLUNK_HEC_QUEUE_MAXSIZE=10000
SPLUNK_HEC_TIMEOUT_SECONDS=10
# Ship the full AgentState per step (large; may include tool data). Off by default.
SPLUNK_HEC_LOG_STATE=false
SPLUNK_HEC_MAX_EVENT_CHARS=200000
