# Backend application settings. Copy to `.env` and fill in real values.
# The resulting `.env` is git-ignored and must never be committed. See ../SECRETS.md.
#
# When running under podman-compose, the compose file overrides the connection URLs
# and sets COOKIE_SECURE=true; the values here apply to local (non-container) runs.

### Core application
SECRET_KEY=changeme-strong-jwt-signing-key
AGENT_API_KEY=changeme-shared-internal-key   # must equal notelite_agent/.env AGENT_API_KEY
HASH_ALGORITHM=HS256
# Send auth cookies only over HTTPS. true in production; false only for plain-HTTP local dev.
COOKIE_SECURE=false

### Database
POSTGRES_DB_URL=postgresql+psycopg://postgres:changeme@localhost:5432/notelite

### Queues and workers
MESSAGE_BROKER_URL=redis://:changeme@localhost:6379/0
CELERY_RESULT_BACKEND=redis://:changeme@localhost:6379/0
INGESTION_TASK_STRING=tasks.process_ingestion   # must match the agent's Celery task name
INGESTION_QUEUE=ingestion

### Observability (optional)
LOKI_URL=http://localhost:3100

### AWS Secrets Manager (production, optional) — see ../SECRETS.md
# AWS_SECRETS_MANAGER_SECRET_ID=notelite/prod
# AWS_REGION=us-east-1
