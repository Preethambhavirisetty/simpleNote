{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "site": { "type": ["string", "null"] },
    "lab": { "type": ["string", "null"] },
    "row": { "type": ["string", "null"] },
    "intent_type": { "type": ["string", "null"] },
    "aggregation": { "type": ["string", "null"] },
    "quarter": { "type": ["string", "null"] },
    "start_date": { "type": ["string", "null"], "format": "date" },
    "end_date": { "type": ["string", "null"], "format": "date" },
    "missing_information": {
      "type": "array",
      "items": { "type": "string" }
    },
    "clarifying_questions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "clarity_level": {
      "enum": ["high", "medium", "low", null]
    },
    "parsing_confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "additionalProperties": false
}
