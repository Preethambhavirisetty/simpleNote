{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Log Volume by Service",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "sum(count_over_time({service=~\".+\"} [1m])) by (service)",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } }
        },
        "overrides": []
      }
    },
    {
      "title": "Backend — Requests",
      "type": "logs",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "{service=\"backend\"} | json | event = `request`",
          "refId": "A"
        }
      ],
      "options": { "showTime": true, "sortOrder": "Descending", "enableLogDetails": true }
    },
    {
      "title": "Backend — Errors (500s + Unhandled)",
      "type": "logs",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "{service=\"backend\"} | json | event = `unhandled_exception` or event = `request_error`",
          "refId": "A"
        }
      ],
      "options": { "showTime": true, "sortOrder": "Descending", "enableLogDetails": true }
    },
    {
      "title": "Agent — Chat Pipeline",
      "type": "logs",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "{service=~\"agent|agent-celery\"} | json | event =~ `chat\\..*`",
          "refId": "A"
        }
      ],
      "options": { "showTime": true, "sortOrder": "Descending", "enableLogDetails": true }
    },
    {
      "title": "Agent — Retrieval Stages",
      "type": "logs",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "{service=~\"agent|agent-celery\"} | json | event =~ `retrieval\\..*`",
          "refId": "A"
        }
      ],
      "options": { "showTime": true, "sortOrder": "Descending", "enableLogDetails": true }
    },
    {
      "title": "Agent — LLM Calls (Enrichment)",
      "type": "logs",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "{service=~\"agent|agent-celery\"} | json | event = `llm.call`",
          "refId": "A"
        }
      ],
      "options": { "showTime": true, "sortOrder": "Descending", "enableLogDetails": true }
    },
    {
      "title": "Agent — Ingestion Pipeline",
      "type": "logs",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "{service=~\"agent|agent-celery\"} | json | event =~ `(ingestion|pipeline)\\..*`",
          "refId": "A"
        }
      ],
      "options": { "showTime": true, "sortOrder": "Descending", "enableLogDetails": true }
    },
    {
      "title": "Agent — All Logs",
      "type": "logs",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 30 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "{service=~\"agent|agent-celery\"}",
          "refId": "A"
        }
      ],
      "options": { "showTime": true, "sortOrder": "Descending", "enableLogDetails": true }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["notelite", "logs"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Notelite Logs",
  "uid": "notelite-logs",
  "version": 2
